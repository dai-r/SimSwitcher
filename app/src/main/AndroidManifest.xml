<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SIM情報の読み取りに必要 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- デュアルSIM端末の場合のみ -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_sim"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_sim"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimSwitcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Quick Settings タイル (ステータスバーから1タップでSIM設定へ)
            Android 7.0 (API 24) 以上で利用可能
        -->
        <service
            android:name=".SimTileService"
            android:exported="true"
            android:icon="@drawable/ic_sim_tile"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
